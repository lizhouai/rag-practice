# DeepSeek V4 Pro through an Anthropic-compatible Messages API.
# Prefer generic LLM_* keys for new setups. Provider-specific aliases are
# supported below for compatibility.
LLM_API_KEY=sk-your-deepseek-key
LLM_BASE_URL=https://api.deepseek.com/anthropic
LLM_MODEL=deepseek-v4-pro
LLM_MAX_TOKENS=1200
# Aliases also accepted by the pipeline:
# ANTHROPIC_API_KEY=sk-your-deepseek-key
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# DEEPSEEK_API_KEY=sk-your-deepseek-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic

# Zhipu embedding-3 through an OpenAI-compatible embeddings endpoint.
EMBEDDING_API_KEY=your-zhipu-key
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
EMBEDDING_MODEL=embedding-3
# Global vector dimension: real embeddings, the local hash fallback, and the
# Qdrant collection all use this value, so vectors stay consistent in every mode.
EMBEDDING_DIMENSIONS=1024
# Aliases also accepted by the pipeline:
# ZHIPU_API_KEY=your-zhipu-key
# ZHIPU_EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# ZHIPUAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# Optional: force index identity provider to local or external.
# EMBEDDING_PROVIDER=external

# Production vector database middleware.
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=production_rag_chunks
# Required for Qdrant Cloud or any authenticated Qdrant endpoint.
# QDRANT_API_KEY=your-qdrant-api-key
# Aliases also accepted by the pipeline:
# VECTOR_DB_URL=http://localhost:6333
# VECTOR_DB_COLLECTION=production_rag_chunks
# VECTOR_DB_API_KEY=your-qdrant-api-key

# Optional local reranker client. Start `python scripts/serve_bge_reranker.py`,
# then uncomment these lines to call the HTTP service from the RAG pipeline.
# RERANKER_PROVIDER=flagembedding
# RERANKER_URL=http://127.0.0.1:8008/rerank
# RERANKER_MODEL=bge-reranker-v2-m3
# RERANKER_TIMEOUT_SECONDS=30

# Optional local reranker service settings used by scripts/serve_bge_reranker.py.
# RERANKER_BACKEND=auto
# RERANKER_MODEL_DIR=D:/models/bge-reranker-v2-m3
# RERANKER_HOST=127.0.0.1
# RERANKER_PORT=8008
# RERANKER_USE_FP16=false
# RERANKER_MAX_LENGTH=1024
# HF_ENDPOINT=https://hf-mirror.com

# Optional proxy settings for Hugging Face dataset/model downloads.
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890

# Optional: choose where SQLite indexes, traces, and metrics are written.
# RAG_RUNTIME_DIR=C:\tmp\production_rag_runtime
