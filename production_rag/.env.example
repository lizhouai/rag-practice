# DeepSeek V4 Pro through Anthropic-compatible Messages API.
ANTHROPIC_API_KEY=sk-your-deepseek-key
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
LLM_MODEL=deepseek-v4-pro
LLM_MAX_TOKENS=1200

# Zhipu embedding-3 through the embeddings endpoint.
ZHIPU_API_KEY=your-zhipu-key
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
EMBEDDING_MODEL=embedding-3
EMBEDDING_DIMENSIONS=1024

# Production vector database middleware.
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=production_rag_chunks
# Required for Qdrant Cloud or any authenticated Qdrant endpoint.
# QDRANT_API_KEY=your-qdrant-api-key

# Optional: choose where SQLite index, traces, and metrics are written.
# RAG_RUNTIME_DIR=C:\tmp\production_rag_starter
